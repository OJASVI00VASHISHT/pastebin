<div class="buttons-wrapper">
  <a href="/" class="logo">Skrappy</a>
  <div class="buttons">
    <a href="/new" class="btn">New</a>
    <% if (locals.canSave) { %>
      <button class="btn" type="submit">Save</button>
    <% } %>
    <% if (locals.id) { %>
      <!-- copy button for paste display pages -->
      <button id="copyBtn" class="btn">Copy</button>
    <% } %>
  </div>
</div>