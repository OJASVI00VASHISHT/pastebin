<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title || 'Skrappy | Share Code Fast' %></title>
  <meta name="description" content="<%= description || '' %>">
  <% if (canonical) { %><link rel="canonical" href="<%= canonical %>"><% } %>
  <meta name="google-site-verification" content="5YMFdBPDJOQJzJ4M4CaREOBe9GJ2x_qO7CQNCJW-HVo" />

  <!-- Open Graph -->s
  <meta property="og:title" content="<%= title || 'Skrappy' %>">
  <meta property="og:description" content="<%= description || '' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= canonical || '' %>">
  <meta property="og:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : '/assets/preview.png' %>">

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title || 'Skrappy' %>">
  <meta name="twitter:description" content="<%= description || '' %>">

  <link rel="stylesheet" href="/styles.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/autosize.js/5.0.0/autosize.min.js" integrity="sha512-zibtOTbkMuTivXGk5b8yJFGLIB1jF90NuV7gwNcVWL3xZx/I1HdkXU2pCZhadsuaS5HMUzabvRqK4WmWeKrwUg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>
<body>
  <form action="/save" method="POST">
    <%- include("_buttons.ejs", { canSave: true }) %>

    <% if (locals.errorMessage) { %>
      <div class="error-message">
        <%= errorMessage %>
      </div>
    <% } %>

    <div class="selection-container">
      <label for="slug">Custom URL (optional):</label>
      <span class="url-prefix">skrappy.onrender.com/</span>
      <input type="text" name="slug" id="slug" placeholder="random-if-empty" value="<%= locals.slug || '' %>" pattern="[a-zA-Z0-9-_]+" title="Only letters, numbers, hyphens, and underscores are allowed.">
    </div>

    <div class="selection-container">
      <label for="expiry">Deletion Policy:</label>
      <select name="expiry" id="expiry">
        <option value="burn" >Burn after 2nd view</option>
        <option value="1h">Expire in 1 Hour</option>
        <option value="24h">Expire in 24 Hours</option>
      </select>
    </div>

    <div class="wrapper">
      <div class="line-numbers">
        &gt;
      </div>
      <textarea autofocus name="value"><%= locals.value %></textarea>
    </div>
  </form>

  <script>
    autosize(document.querySelector('textarea'))
  </script>
</body>
</html>